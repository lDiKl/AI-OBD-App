# Copy this to .env and fill in your values
# cp .env.example .env

# Database (Docker defaults)
DATABASE_URL=postgresql+asyncpg://obd_user:obd_pass@localhost:5432/obd_db
DATABASE_POOL_SIZE=10

# Redis (Docker defaults)
REDIS_URL=redis://localhost:6379/0

# Firebase — provide either JSON string or file path
# Option 1: JSON string (for production/CI)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
# Option 2: file path (for local dev)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# AI / LLM
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_API_KEY=sk_test_...       # alias для Stripe CLI (читает STRIPE_API_KEY из env)
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (Stripe Dashboard → Products → каждый продукт → Price → copy price_...)
STRIPE_PRICE_B2C_PREMIUM=price_...
STRIPE_PRICE_B2B_BASIC=price_...
STRIPE_PRICE_B2B_PRO=price_...

# Redirect URLs after Stripe Checkout (dev)
B2C_SUCCESS_URL=driverai://payment/success
B2C_CANCEL_URL=driverai://payment/cancel
B2B_SUCCESS_URL=http://localhost:5173/billing/success
B2B_CANCEL_URL=http://localhost:5173/billing

# CORS — добавь свой origin если нужно
ALLOWED_ORIGINS=["http://localhost:5173"]

# App
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production
