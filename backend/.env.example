# ============================================================
# AI OBD Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env!
# ============================================================

# --- App ---
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_obd
DATABASE_POOL_SIZE=10

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Firebase Admin SDK ---
# Download from Firebase Console → Project Settings → Service Accounts
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json
# OR pass as JSON string:
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# --- AI / LLM ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
LOCAL_LLM_URL=http://localhost:11434  # Ollama default

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_B2C_PREMIUM=price_...
STRIPE_PRICE_B2B_BASIC=price_...
STRIPE_PRICE_B2B_PRO=price_...

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,https://app.shopai.com

# --- App URLs ---
B2C_SUCCESS_URL=https://app.driverai.com/payment/success
B2C_CANCEL_URL=https://app.driverai.com/payment/cancel
B2B_SUCCESS_URL=https://app.shopai.com/billing/success
B2B_CANCEL_URL=https://app.shopai.com/billing/cancel
