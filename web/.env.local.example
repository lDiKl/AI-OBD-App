# Copy to .env.local and fill in your Firebase Web app config
# Firebase Console → Project Settings → Your apps → Web app → SDK config
#
# In Docker: VITE_API_BASE_URL must be empty so Vite proxy handles /api/* requests.
# The proxy target (http://api:8000) is set automatically by docker-compose.

VITE_API_BASE_URL=

VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
